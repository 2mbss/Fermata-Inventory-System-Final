rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.uid == userId || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Super Admin');
    }

    // Products — authenticated users can read; write requires auth
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Transactions — authenticated users
    match /transactions/{txId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Refunds — authenticated users
    match /refunds/{refundId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Bookings — authenticated users
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Inventory Logs — authenticated users
    match /inventoryLogs/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
